{
  "name": "weizhi-agent",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:mac": "electron-builder --mac --universal",
    "dist:win": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.weizhi.agent",
    "productName": "Weizhi Agent",
    "files": ["main.js", "frontend-dist/**/*", "resources/**/*"],
    "directories": { "output": "dist" }
  }
}
